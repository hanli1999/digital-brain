generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model InboxItem {
  id          String   @id @default(cuid())
  title       String
  content     String   @default("")
  source      String   @default("manual")
  imageUrls   String   @default("[]")
  status      String   @default("pending")
  routeTarget String?
  routedTo    String?
  tags        String   @default("[]")
  category    String   @default("")
  aiSummary   String   @default("")
  mood        String   @default("")
  collectedAt String   @default("")
  sourceUrl   String   @default("")
  feishuId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  status      String   @default("todo")
  action      String   @default("")
  tags        String   @default("[]")
  feishuId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tool {
  id          String   @id @default(cuid())
  name        String
  category    String   @default("")
  description String   @default("")
  url         String   @default("")
  corePower   String   @default("")
  initScript  String   @default("")
  rating      String   @default("")
  record      String   @default("")
  tags        String   @default("[]")
  feishuId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Method {
  id        String   @id @default(cuid())
  title     String
  essence   String   @default("")
  status    String   @default("")
  type      String   @default("")
  learnedDate String @default("")
  storage   String   @default("")
  related   String   @default("")
  tags      String   @default("[]")
  feishuId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id          String   @id @default(cuid())
  title       String
  author      String   @default("")
  abstract    String   @default("")
  url         String   @default("")
  keywords    String   @default("")
  type        String   @default("")
  status      String   @default("")
  importance  String   @default("")
  publishedAt String   @default("")
  snippet     String   @default("")
  tags        String   @default("[]")
  feishuId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AiMechanism {
  id               String   @id @default(cuid())
  name             String
  component        String   @default("")
  coreIdea         String   @default("")
  features         String   @default("")
  featuresDetail   String   @default("")
  examples         String   @default("")
  scenarios        String   @default("")
  scenariosDetail  String   @default("")
  source           String   @default("")
  tags             String   @default("[]")
  feishuId         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Resource {
  id        String   @id @default(cuid())
  name      String
  url       String   @default("")
  type      String   @default("")
  stock     String   @default("")
  status    String   @default("")
  detail    String   @default("")
  tags      String   @default("[]")
  feishuId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FileAsset {
  id         String   @id @default(cuid())
  filename   String
  text       String   @default("")
  date       String   @default("")
  attachment String   @default("")
  size       Int      @default(0)
  mimeType   String   @default("")
  url        String   @default("")
  tags       String   @default("[]")
  feishuId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  content     String   @default("")
  status      String   @default("")
  priority    String   @default("")
  startTime   String
  endTime     String   @default("")
  allDay      String   @default("")
  projectId   String   @default("")
  tags        String   @default("[]")
  feishuId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Jiyuanlu {
  id              String   @id @default(cuid())
  detail          String
  description     String   @default("")
  status          String   @default("")
  action          String   @default("")
  tags            String   @default("[]")
  relatedMethod   String   @default("")
  actionLog       String   @default("")
  recordId        String   @default("")
  feishuId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Metric {
  id        String   @id @default(cuid())
  name      String
  value     Float    @default(0)
  unit      String   @default("")
  category  String   @default("")
  timestamp DateTime @default(now())
  feishuId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SearchIndex {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  title      String
  content    String   @default("")
  tags       String   @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId])
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique @default("")
  passwordHash String   @default("")
  avatar       String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeishuSyncLog {
  id        String   @id @default(cuid())
  direction String
  tableName String
  status    String
  detail    String   @default("")
  createdAt DateTime @default(now())
}

model Insight {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  category  String   @default("")
  source    String   @default("")
  tags      String   @default("[]")
  feishuId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  detail    String   @default("")
  createdAt DateTime @default(now())
}
